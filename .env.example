# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram (voice transcription)
DEEPGRAM_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_STUDIO_PRICE_ID=price_...

# Auth server
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (auth-server)
DATABASE_URL=postgresql://user:password@localhost:5432/animora

# Redis (session state + rate limiting)
REDIS_URL=redis://localhost:6379/0

# IP reputation / abuse detection
IPQS_API_KEY=...

# Backend URLs (used by addon)
AI_BACKEND_URL=wss://api.animora.tech/ws
AUTH_SERVER_URL=https://auth.animora.tech
WEBSITE_URL=https://animora.tech

# Build signing (CI only)
WINDOWS_CERT_PATH=
WINDOWS_CERT_PASSWORD=
MACOS_SIGNING_IDENTITY=
MACOS_NOTARIZATION_APPLE_ID=
MACOS_NOTARIZATION_PASSWORD=
MACOS_NOTARIZATION_TEAM_ID=
