@@ -833,6 +833,30 @@ void blo_do_versions_userdef(UserDef *userdef)
     userdef->pad_rot_angle = 15.0f;
   }
 
+  /* Animora factory defaults — visual/preference seeds that are one-shot
+   * (user is free to change them later). Gated by a "first run" marker. */
+  if (!USER_VERSION_ATLEAST(501, 99)) {
+    userdef->smooth_viewtx          = 300;   /* 300ms viewport pan/zoom ease */
+    userdef->pie_animation_timeout  = 50;    /* smooth pie-menu unfold */
+    userdef->pie_initial_timeout    = 30;
+    userdef->viewport_aa            = SCE_DISPLAY_AA_FXAA;  /* cheap post-process AA — crisp edges */
+    if (userdef->ui_scale <= 0.0f) {
+      userdef->ui_scale = 1.0f;
+    }
+  }
+
+  /* Animora AI panel — core to the product. Must be ensured on EVERY load
+   * (not just first-run) because the SPACE_ANIMORA editor area is empty
+   * without this addon's Python panels registering against it. The user
+   * report "AI panel is completely blank" was caused by gating this call
+   * behind USER_VERSION_ATLEAST — fresh userprefs created by recent
+   * Animora builds carry a version >= the gate, so the gate was always
