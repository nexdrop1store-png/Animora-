# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Environment variables — never commit real .env files
.env
.env.local
.env.production
.env.staging

# Blender fork — entire tree excluded from this repo (7+ GB).
# Clone separately from projects.blender.org and apply patches/animora-native.patch.
# See patches/README.md for instructions.
blender-fork/
*.blend1
*.blend2

# Build / probe scratch files
build_log.txt
tmp_probe.py
test_addon_load.py

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
release/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.pkg

# Installer temp
installer/windows/build/
installer/macos/build/
installer/linux/build/

# Self-extracting installer payload — a 272 MB 7z archive regenerated by
# scripts/stage_for_installer.py from the staged Animora bits. Exceeds
# GitHub's 100 MB hard limit; rebuild locally via the script before
# producing a Windows installer.
installer/windows/sfx/payload.7z

# Secrets / certs (never commit)
*.pem
*.key
*.p12
*.pfx
*.crt

# Animora user data (generated at runtime)
~/.animora/

# Runtime logs
dev_server.log
*.log

# Claude Code local state
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Stage 3C captured demonstrations (local artifact)
demonstrations/

# Sprint 4C recorded sessions (local capture artifact — large JSON turns)
recordings/

# Pytest scratch dirs (tmp_path artifacts that leak into the repo root)
.tmp-pytest/
pytest-of-*/
.pytest_cache/
